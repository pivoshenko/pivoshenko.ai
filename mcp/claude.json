{
  "mcpServers": {
    "logfire": {
      "command": "npx",
      "args": ["-y", "mcp-remote", "https://logfire-eu.pydantic.dev/mcp"]
    },
    "notion": {
      "command": "npx",
      "args": ["-y", "mcp-remote", "https://mcp.notion.com/mcp"]
    },
    "linear": {
      "command": "npx",
      "args": ["-y", "mcp-remote", "https://mcp.linear.app/mcp"]
    },
    "github": {
      "command": "npx",
      "args": ["-y", "mcp-remote", "https://api.githubcopilot.com/mcp"],
      "env": {
        "GITHUB_PAT_TOKEN": "${GITHUB_PAT_TOKEN}"
      }
    },
    "obsidian": {
      "command": "npx",
      "args": ["@mauricio.wolff/mcp-obsidian@latest", "<vault_path>"]
    }
  }
}
